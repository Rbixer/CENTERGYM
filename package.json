{
  "name": "gymencuesta",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prestart": "prisma generate",
    "dev": "npm run free:4178 && sh scripts/print-dev-mobile-hint.sh && prisma generate && prisma db push && next dev --webpack -H 0.0.0.0 -p 4178",
    "dev:turbo": "npm run free:4178 && sh scripts/print-dev-mobile-hint.sh && prisma generate && prisma db push && next dev --turbo -H 0.0.0.0 -p 4178",
    "free:4178": "sh scripts/free-port-4178.sh",
    "dev:fresh": "npm run free:4178 && npm run dev",
    "build": "prisma generate && next build",
    "start": "next start -H 0.0.0.0 -p 4178",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
