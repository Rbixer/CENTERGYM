generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Opción de Turno / Entrenador (lista desplegable del alumno)
model TrainerGroup {
  id          String       @id @default(cuid())
  label       String
  sortOrder   Int          @default(0)
  submissions Submission[]
}

model Question {
  id        String           @id @default(cuid())
  text      String
  sortOrder Int              @default(0)
  options   QuestionOption[]
  answers   Answer[]
}

model QuestionOption {
  id         String     @id @default(cuid())
  questionId String
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  sortOrder  Int        @default(0)
  answers    Answer[]   @relation("SelectedOption")
}

model Submission {
  id             String       @id @default(cuid())
  trainerGroupId String
  trainerGroup   TrainerGroup @relation(fields: [trainerGroupId], references: [id])
  submittedAt    DateTime     @default(now())
  /// Valoración 1–5 estrellas del entrenador / turno elegido
  trainerRating  Int?
  /// Comentario libre del alumno sobre el entrenador / turno
  trainerComment String?
  /// UUID generado en el cliente para idempotencia: si llega el mismo `requestId` dos veces (doble click, reintento), se devuelve el mismo Submission en vez de duplicar.
  requestId      String?      @unique
  /// Hash HMAC truncado de la IP del cliente (no es la IP cruda). Solo para auditoría/anti‑abuso, nunca se devuelve al cliente.
  ipHash         String?
  answers        Answer[]
}

model Answer {
  id               String         @id @default(cuid())
  submissionId     String
  submission       Submission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId       String
  question         Question       @relation(fields: [questionId], references: [id])
  selectedOptionId String
  selectedOption   QuestionOption @relation("SelectedOption", fields: [selectedOptionId], references: [id])
}

/// Producto a la venta (catálogo para alumnos en /tienda)
model Product {
  id         String           @id @default(cuid())
  name       String
  priceCents Int
  imageUrl   String
  sortOrder  Int              @default(0)
  active     Boolean          @default(true)
  createdAt  DateTime         @default(now())
  lines      SalesOrderLine[]
}

/// Pedido de productos enviado desde la tienda pública
model SalesOrder {
  id           String           @id @default(cuid())
  studentName  String?
  studentNote  String?
  submittedAt  DateTime         @default(now())
  verified     Boolean          @default(false)
  verifiedAt   DateTime?
  /// Suma de `priceCents*quantity` en el momento del pedido (snapshot). Calculado
  /// y persistido por el servidor para que el total no dependa del cliente.
  subtotalCents  Int           @default(0)
  /// Descuento aplicado en centavos (positivo). 0 cuando no hay código.
  discountCents  Int           @default(0)
  /// `subtotalCents - discountCents`, nunca menor que 0.
  totalCents     Int           @default(0)
  /// Código que se canjeó (si lo hubo). Persiste el texto literal del código
  /// aunque el `PromoCode` se desactive o borre.
  promoCode      String?
  /// Relación opcional al canje. La línea de canje sí guarda referencia fuerte.
  promoRedemptionId String?    @unique
  promoRedemption PromoRedemption? @relation("OrderRedemption", fields: [promoRedemptionId], references: [id], onDelete: SetNull)
  lines        SalesOrderLine[]
}

model SalesOrderLine {
  id        String     @id @default(cuid())
  orderId   String
  order     SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int        @default(1)
  /// Precio unitario al momento del pedido (snapshot histórico). Si después
  /// cambias el precio del producto, los pedidos antiguos siguen mostrando
  /// el precio que cobraste.
  priceCents Int       @default(0)

  @@unique([orderId, productId])
}

/// Código de promoción canjeable en la tienda o emitido como recompensa
/// (p. ej. al enviar la encuesta). Un solo modelo cubre todos los tipos
/// (`kind`) y reglas (`discountType`).
model PromoCode {
  id            String   @id @default(cuid())
  /// Código en mayúsculas, único (ej. "VERANO20"). Indexado y único.
  code          String   @unique
  /// Descripción interna mostrada en el admin.
  description   String   @default("")
  /// Casos de uso:
  /// - "store": descuento en /tienda
  /// - "survey_reward": código único emitido al completar la encuesta
  /// - "day_pass": pase de día (futura iteración)
  /// - "membership": descuento en mensualidad (futura iteración)
  /// - "referral": código de referido (futura iteración)
  kind          String   @default("store")
  /// "percent" | "fixed" | "free"
  discountType  String   @default("percent")
  /// Significado depende de `discountType`:
  /// - percent: 1..100 (porcentaje a descontar)
  /// - fixed:   valor en centavos a descontar
  /// - free:    se ignora (descuento = subtotal)
  discountValue Int      @default(0)
  /// Subtotal mínimo en centavos para aplicar el código.
  minSubtotalCents Int?
  /// Número total de canjes permitidos (null = ilimitado).
  maxUses       Int?
  /// Canjes ya consumidos (incrementado atómicamente en transacción).
  uses          Int      @default(0)
  /// Canjes máximos por la misma "identidad" (ip/cookie). null = sin tope.
  maxUsesPerUser Int?    @default(1)
  validFrom     DateTime?
  validUntil    DateTime?
  /// Cuando `kind = survey_reward`, este campo guarda el id del `Submission`
  /// que lo originó para idempotencia: si llega el mismo submit dos veces,
  /// solo se crea un código.
  submissionId  String?  @unique
  /// Notas internas / contexto creado por el admin.
  notes         String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  redemptions   PromoRedemption[]
}

/// Cada vez que alguien canjea un `PromoCode` se crea una fila aquí. Sirve
/// para auditar, reportar y, en el caso de la tienda, queda relacionada con
/// el pedido (`SalesOrder.promoRedemptionId`).
model PromoRedemption {
  id           String      @id @default(cuid())
  codeId       String
  code         PromoCode   @relation(fields: [codeId], references: [id], onDelete: Cascade)
  /// Hash HMAC truncado de la IP + UA (o cookie estable) para contar usos por
  /// usuario sin guardar PII.
  userKey      String?
  amountSavedCents Int     @default(0)
  redeemedAt   DateTime    @default(now())
  /// Relación inversa con el pedido cuando aplica.
  order        SalesOrder? @relation("OrderRedemption")

  @@index([codeId])
  @@index([userKey])
}

/// Ejercicio individual de la biblioteca: GIF, nombre, descripción, categoría.
/// Antes se llamaba "Rutina" en la UI; pasamos a llamarlo "Ejercicio" porque
/// ahora una RUTINA es una sesión que contiene varios de estos ejercicios
/// con sus propias series y repeticiones (modelo `Workout` + `WorkoutItem`).
/// Mantenemos el nombre de tabla `Routine` en la BD para no romper los datos
/// existentes (~60 filas ya cargadas con sus GIFs).
model Routine {
  id           String         @id @default(cuid())
  name         String
  description  String
  gifUrl       String
  /// URL relativa a un thumbnail JPG/WebP de baja resolución (~10-20KB) que
  /// se usa en listados y selectores donde no necesitamos la animación
  /// completa. El GIF (`gifUrl`) se reserva para detalle de rutina y modo
  /// entrenamiento guiado. Null cuando no se ha generado todavía.
  thumbUrl     String?
  /// Slug de zona/tipo (`lib/routine-categories`): biceps, piernas, etc.
  category     String         @default("general")
  /// Equipamiento requerido: "body weight", "dumbbell", "barbell", "cable",
  /// "kettlebell", "band", "machine", etc. Slug interno, mostrado en la UI
  /// vía `lib/equipment.ts`. Null cuando no se conoce (ej. ejercicios creados
  /// manualmente antes de añadir este campo).
  equipment    String?
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  workoutItems WorkoutItem[]
}

/// Rutina-sesión: agrupa varios ejercicios con sus series y repeticiones.
/// Ejemplo: "Empuje día 1" → 4-5 ejercicios encadenados con sets/reps cada uno.
/// Se muestra a los alumnos en /rutina/categoria/<slug>. Sustituye a la
/// visualización antigua de "Routine sueltas".
model Workout {
  id          String        @id @default(cuid())
  name        String
  description String        @default("")
  /// Slug de categoría (`lib/routine-categories`): zona principal o tipo.
  category    String        @default("general")
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  items       WorkoutItem[]
}

/// Cada ejercicio dentro de una rutina-sesión, con sets/reps y orden.
/// Borrar la rutina (Workout) elimina sus ítems; borrar el ejercicio de
/// biblioteca (Routine) lo bloqueamos con Restrict para no romper las
/// rutinas que lo referencian.
model WorkoutItem {
  id          String   @id @default(cuid())
  workoutId   String
  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    Routine  @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  /// Número de series (ej. 4).
  sets        Int      @default(3)
  /// Repeticiones como texto: admite "12", "12-15", "al fallo", "30 seg".
  reps        String   @default("12")
  /// Descanso entre series en segundos (opcional, ej. 60, 90).
  restSec     Int?
  /// Nota libre por ejercicio dentro de esta rutina (técnica concreta, peso, RIR, etc).
  notes       String?
  sortOrder   Int      @default(0)

  @@index([workoutId])
  @@index([exerciseId])
}
