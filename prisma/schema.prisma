generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Opción de Turno / Entrenador (lista desplegable del alumno)
model TrainerGroup {
  id          String       @id @default(cuid())
  label       String
  sortOrder   Int          @default(0)
  submissions Submission[]
}

model Question {
  id        String           @id @default(cuid())
  text      String
  sortOrder Int              @default(0)
  options   QuestionOption[]
  answers   Answer[]
}

model QuestionOption {
  id         String     @id @default(cuid())
  questionId String
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  sortOrder  Int        @default(0)
  answers    Answer[]   @relation("SelectedOption")
}

model Submission {
  id             String       @id @default(cuid())
  trainerGroupId String
  trainerGroup   TrainerGroup @relation(fields: [trainerGroupId], references: [id])
  submittedAt    DateTime     @default(now())
  /// Valoración 1–5 estrellas del entrenador / turno elegido
  trainerRating  Int?
  /// Comentario libre del alumno sobre el entrenador / turno
  trainerComment String?
  /// UUID generado en el cliente para idempotencia: si llega el mismo `requestId` dos veces (doble click, reintento), se devuelve el mismo Submission en vez de duplicar.
  requestId      String?      @unique
  /// Hash HMAC truncado de la IP del cliente (no es la IP cruda). Solo para auditoría/anti‑abuso, nunca se devuelve al cliente.
  ipHash         String?
  answers        Answer[]
}

model Answer {
  id               String         @id @default(cuid())
  submissionId     String
  submission       Submission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId       String
  question         Question       @relation(fields: [questionId], references: [id])
  selectedOptionId String
  selectedOption   QuestionOption @relation("SelectedOption", fields: [selectedOptionId], references: [id])
}

/// Producto a la venta (catálogo para alumnos en /tienda)
model Product {
  id         String           @id @default(cuid())
  name       String
  priceCents Int
  imageUrl   String
  sortOrder  Int              @default(0)
  active     Boolean          @default(true)
  createdAt  DateTime         @default(now())
  lines      SalesOrderLine[]
}

/// Pedido de productos enviado desde la tienda pública
model SalesOrder {
  id           String           @id @default(cuid())
  studentName  String?
  studentNote  String?
  submittedAt  DateTime         @default(now())
  verified     Boolean          @default(false)
  verifiedAt   DateTime?
  lines        SalesOrderLine[]
}

model SalesOrderLine {
  id        String     @id @default(cuid())
  orderId   String
  order     SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int        @default(1)

  @@unique([orderId, productId])
}

/// Rutina de entrenamiento (página pública /rutina, admin /admin/rutinas)
model Routine {
  id          String   @id @default(cuid())
  name        String
  description String
  gifUrl      String
  /// Slug de zona/tipo (`lib/routine-categories`): biceps, piernas, etc.
  category    String   @default("general")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
