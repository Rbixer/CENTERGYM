# busy_timeout evita bloqueos largos si SQLite está ocupado (p. ej. varias pestañas / dev).
DATABASE_URL="file:./dev.db?busy_timeout=10000"
ADMIN_PASSWORD="tu-clave-segura"
ADMIN_SECRET="cadena-secreta-larga-para-firmar-sesiones"

# Opcional: ilustraciones de rutinas con OpenAI (DALL·E 3 → PNG en /images/routines/).
# Pon la clave en .env o .env.local en la raíz del repo; luego reinicia `npm run dev`.
# OPENAI_API_KEY="sk-..."

# Misma app: encuesta en http://localhost:4178/ y login en http://localhost:4178/admin/login
PORT=4178

# En el móvil (misma Wi‑Fi, datos móviles apagados, sin VPN): usa http://IP_DEL_PC:4178
# (http, no https) — no uses localhost. Prueba primero: http://IP:4178/api/health
# (debe devolver {"ok":true}).
# `sh scripts/print-dev-mobile-hint.sh` sugiere la IP correcta (evita VPN primero en hostname -I).
# Tras cambiar .env, reinicia `npm run dev`. Si en blanco o 403 en /_next, define:
# NEXT_PUBLIC_APP_URL="http://192.168.1.35:4178"
# Copia el listado de IPs de `npm run dev` o `sh scripts/print-dev-mobile-hint.sh`, línea (opcional):
# ALLOWED_DEV_ORIGINS="192.168.1.35,10.0.0.2"
# Si probaste antes con localhost y luego con IP: borra datos del sitio en el móvil o desactiva SW
# (en desarrollo el proyecto no registra service worker a propósito).
